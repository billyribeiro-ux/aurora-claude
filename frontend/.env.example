# AURORA-SWING Console — environment configuration
#
# Copy this file to `.env` and fill in your key:
#     cp .env.example .env
#
# Financial Modeling Prep API key (https://site.financialmodelingprep.com/developer/docs).
# The key is read ONLY on the server (via $env/dynamic/private) and is never
# shipped to the browser. Without a key the console runs in SYNTHETIC data mode
# so the UI stays fully functional for review.
FMP_API_KEY=

# Operating mode shown in the UI banner: LIVE | PAPER | DEMO
# Per the deployment protocol, real capital requires 3-6 months of PAPER first.
AURORA_MODE=PAPER

# Comma-separated instrument universe (optional; a sensible default is used).
# AURORA_UNIVERSE=SPY,QQQ,IWM,NVDA,AAPL,MSFT,AMD,XLK,XLF,XLE
